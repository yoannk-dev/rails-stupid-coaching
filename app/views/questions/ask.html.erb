<p>Ask your coach anything</p>
<form action="/answer" data-turbo="false">
  <div class="form-group mb-3">
    <label for="question">Your question</label>
    <input type="text" class="form-control" id="question" name="question" aria-describedby="questionHelp" placeholder="Ask your question to the stupid coach">
  </div>
  <button type="submit" class="btn btn-primary">Ask</button>
</form>
